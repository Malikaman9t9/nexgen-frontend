# Google PageSpeed Insights API Key
SPEED_API_KEY=your_google_api_key_here

# Google Gemini API Key (for AI recommendations)
GEMINI_API_KEY=your_gemini_api_key_here

# RapidAPI Key (unified — works for traffic, Moz DA/PA, SEO Audit, FAST Audit, Keyword Insights, Semrush)
RAPIDAPI_KEY=your_rapidapi_key_here

# Supabase Project URL & Anon Key
# Get these from your Supabase project dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Comma-separated list of allowed CORS origins (use * for all)
# Production: https://nexgenweblab.com,https://www.nexgenweblab.com,https://tools.nexgenweblab.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
