{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/((?!robots.txt|sitemap.xml|assets/.*).*)", "destination": "/index.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/blog/:slug", "destination": "/blog/blog-post.html?slug=:slug" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/cookie-policy", "destination": "/cookie-policy.html" },
    { "source": "/disclaimer", "destination": "/disclaimer.html" },
    { "source": "/editorial-guidelines", "destination": "/editorial-guidelines.html" },
    { "source": "/auth", "destination": "/auth.html" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/dashboard", "destination": "/admin/dashboard.html" },
    { "source": "/admin/editor", "destination": "/admin/editor.html" },
    { "source": "/payment", "destination": "/payment.html" },
    { "source": "/upgrade", "destination": "/upgrade.html" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/auth-callback", "destination": "/auth-callback.html" },
    { "source": "/solutions", "destination": "/solutions.html" },
    { "source": "/solutions/:slug", "destination": "/solutions/:slug.html" },
    { "source": "/learn", "destination": "/learn.html" },
    { "source": "/learn/:slug", "destination": "/learn/:slug.html" }
  ],
  "headers": [
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
