{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/dashboard", "destination": "/admin/dashboard.html" },
    { "source": "/admin/editor", "destination": "/admin/editor.html" },
    { "source": "/admin/:path*", "destination": "/admin/:path*" }
  ]
}
